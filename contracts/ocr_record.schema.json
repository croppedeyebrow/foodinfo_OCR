{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neulsom.local/schemas/ocr-record-1.0.json",
  "title": "Kurly disclosure OCR record",
  "type": "object",
  "required": [
    "schema_version",
    "source_site",
    "original_product_id",
    "product_name",
    "product_url",
    "ocr_raw_text",
    "parser_version"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "source_site": { "const": "KURLY_N_MART" },
    "original_product_id": { "type": "string", "minLength": 1 },
    "product_name": { "type": "string", "minLength": 1 },
    "product_url": { "type": "string", "format": "uri" },
    "source_image_url": { "type": ["string", "null"], "format": "uri" },
    "image_sha256": { "type": ["string", "null"] },
    "food_type_raw": { "type": ["string", "null"] },
    "expiration_info_raw": { "type": ["string", "null"] },
    "storage_method_raw": { "type": ["string", "null"] },
    "ocr_raw_text": { "type": "string" },
    "ocr_engine": { "type": ["string", "null"] },
    "ocr_engine_version": { "type": ["string", "null"] },
    "ocr_confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "parser_version": { "type": "string", "minLength": 1 },
    "collected_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": true
}
